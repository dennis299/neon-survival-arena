# Global leaderboard (Supabase). Get these from your Supabase project's
# Settings → API. Both are safe to expose in the client — the anon key only
# grants the permissions your Row Level Security policies allow (here: insert
# and read on the public `scores` table, nothing else).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
